generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  billingCycles  BillingCycle[]
  categories     Category[]
  paymentMethods PaymentMethod[]
  bankAccounts       BankAccount[]
  investments        Investment[]
  patrimonySnapshots PatrimonySnapshot[]

  @@map("users")
}

enum BillingCycleStatus {
  open
  closed
}

model BillingCycle {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  name      String
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  salary    Decimal            @db.Decimal(15, 2)
  status    BillingCycleStatus @default(open)
  closedAt  DateTime?          @map("closed_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  patrimonySnapshot PatrimonySnapshot?

  @@index([userId])
  @@map("billing_cycles")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  color     String?
  isActive  Boolean  @default(true) @map("is_active")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("categories")
}

enum PaymentMethodType {
  credit
  debit
}

model PaymentMethod {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  name      String
  type      PaymentMethodType
  dueDay    Int?              @map("due_day")
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

enum BankAccountType {
  checking
  savings
  wallet
}

enum InvestmentType {
  fixed_income
  variable_income
  crypto
  real_estate
  other
}

enum LiquidityType {
  daily
  monthly
  at_maturity
}

model BankAccount {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  name        String
  institution String
  type        BankAccountType
  balance     Decimal         @default(0) @db.Decimal(15, 2)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_accounts")
}

model Investment {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  name          String
  type          InvestmentType
  institution   String
  appliedAmount Decimal        @db.Decimal(15, 2) @map("applied_amount")
  currentValue  Decimal        @db.Decimal(15, 2) @map("current_value")
  liquidity     LiquidityType
  maturityDate  DateTime?      @map("maturity_date")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("investments")
}

model PatrimonySnapshot {
  id                 String       @id @default(uuid())
  userId             String       @map("user_id")
  billingCycleId     String       @unique @map("billing_cycle_id")
  totalBankAccounts  Decimal      @db.Decimal(15, 2) @map("total_bank_accounts")
  totalInvestments   Decimal      @db.Decimal(15, 2) @map("total_investments")
  totalAssets        Decimal      @db.Decimal(15, 2) @map("total_assets")
  futureInstallments Decimal      @db.Decimal(15, 2) @map("future_installments")
  netPatrimony       Decimal      @db.Decimal(15, 2) @map("net_patrimony")
  snapshotDate       DateTime     @map("snapshot_date")
  createdAt          DateTime     @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingCycle BillingCycle @relation(fields: [billingCycleId], references: [id], onDelete: Cascade)

  @@unique([userId, billingCycleId])
  @@index([userId])
  @@map("patrimony_snapshots")
}
